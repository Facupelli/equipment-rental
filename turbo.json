{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**/*.ts", "jest.config.ts", "tsconfig.json"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "inputs": [
        "src/**/*.ts",
        "test/**/*.ts",
        "jest.e2e.config.ts",
        "tsconfig.json"
      ]
    }
  }
}
