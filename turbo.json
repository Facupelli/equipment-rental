{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".output/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false
    },

    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "jest.config.ts"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:cov": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "jest.config.ts"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "jest.config.integration.ts"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "test/**/*.ts", "jest.config.e2e.ts"],
      "cache": false
    }
  }
}
