generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}


model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  isActive     Boolean  @default(true) @map("is_active")
  tenantId     String   @map("tenant_id")
  roleId       String   @map("role_id")
  
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  role         Role     @relation(fields: [roleId], references: [id])

  @@index([tenantId]) // Critical for RLS
  @@map("users")
}

model Role {
  id          String       @id @default(cuid())
  name        String
  description String?
  isSystem    Boolean      @default(false) @map("is_system")
  tenantId    String       @map("tenant_id")
  
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  users       User[]
  permissions Permission[]

  @@unique([tenantId, name]) // Role names unique per tenant
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id         String   @id @default(cuid())
  action     String   // e.g., "read", "manage"
  subject    String   // e.g., "Booking"
  conditions Json?    // CASL conditions
  fields     String?  // Optional field masking
  inverted   Boolean  @default(false)
  roleId     String   @map("role_id")

  role       Role     @relation(fields: [roleId], references: [id])

  @@index([roleId])
  @@map("permissions")
}

// --- Enums ---

enum TrackingType {
  SERIALIZED
  BULK
}

enum InventoryStatus {
  OPERATIONAL
  MAINTENANCE
  RETIRED
}

enum BookingStatus {
  PENDING_CONFIRMATION 
  RESERVED
  ACTIVE
  COMPLETED
  CANCELLED
}

// --- Core Entities (Tenancy & Organization) ---

model Tenant {
  id               String     @id @default(uuid())
  name             String
  slug             String     @unique
  planTier         String     @map("plan_tier")
  isActive         Boolean    @default(true) @map("is_active")
  pricingConfig    Json?      @map("pricing_config") 

  users            User[]
  roles            Role[]
  createdAt        DateTime   @default(now()) @map("created_at")

  // Relations
  locations        Location[]
  owners           Owner[]
  products         Product[]
  inventoryItems   InventoryItem[]
  customers        Customer[]
  promotions       Promotion[]
  bookings         Booking[]
  bookingDiscounts BookingDiscount[]
  billingUnits     BillingUnit[]
  pricingTiers     PricingTier[]
  blackoutPeriods  BlackoutPeriod[] 

  @@map("tenants")
}

model Location {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  name      String
  address   Json    // Flexible structure (street, city, geo)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]

  @@index([tenantId]) // RLS Index
  @@map("locations")
}

model Owner {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  name           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]
  bookingItems   BookingLineItem[] // For payout reporting

  @@index([tenantId]) // RLS Index
  @@map("owners")
}

// --- Inventory Entities ---

model Product {
  id                String        @id @default(uuid())
  tenantId          String          @map("tenant_id")
  name              String
  trackingType      TrackingType  @map("tracking_type")
  attributes        Json          // Flexible specs (weight, power, etc.)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItems    InventoryItem[]
  pricingTiers      PricingTier[] 
  bookingLineItems  BookingLineItem[] 

  @@index([tenantId])
  @@map("products")
}

model InventoryItem {
  id             String          @id @default(uuid())
  tenantId       String          @map("tenant_id")
  productId      String          @map("product_id")
  locationId     String          @map("location_id")
  ownerId        String          @map("owner_id")
  status         InventoryStatus @default(OPERATIONAL)
  totalQuantity  Int             @map("total_quantity") // 1 for SERIALIZED, >=1 for BULK
  serialNumber   String?         @map("serial_number")
  purchaseDate   DateTime?       @map("purchase_date") @db.Date
  purchaseCost   Decimal?        @map("purchase_cost") @db.Decimal(10, 2)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Restrict)
  owner        Owner        @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  
  bookingLineItems BookingLineItem[]
  pricingTiers     PricingTier[]    // New: Item-level override pricing
  blackoutPeriods  BlackoutPeriod[]

  @@index([tenantId]) // RLS Index
  @@index([productId])
  @@index([locationId])
  @@index([ownerId])
  @@map("inventory_items")
}

model BillingUnit {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  name          String        // "half_day" | "full_day" | "week"
  durationHours Decimal       @map("duration_hours") @db.Decimal(6, 2)
  sortOrder     Int           @map("sort_order")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  pricingTiers  PricingTier[]
  tenant        Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@map("billing_units")
}

model PricingTier {
  id              String         @id @default(uuid())
  tenantId        String         @map("tenant_id")
  productId       String         @map("product_id")
  inventoryItemId String?        @map("inventory_item_id")
  billingUnitId   String         @map("billing_unit_id")
  fromUnit        Decimal        @map("from_unit") @db.Decimal(5, 2)
  pricePerUnit    Decimal        @map("price_per_unit") @db.Decimal(10, 2)
  currency        String         @db.Char(3)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  product         Product?       @relation(fields: [productId], references: [id])
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  billingUnit     BillingUnit    @relation(fields: [billingUnitId], references: [id])

  @@unique([tenantId, productId, inventoryItemId, billingUnitId, fromUnit])
  @@map("pricing_tiers")
}

model BlackoutPeriod {
  id              String                    @id @default(uuid())
  tenantId        String                    @map("tenant_id")
  inventoryItemId String                    @map("inventory_item_id")
  reason          String
  blockedPeriod   Unsupported("tstzrange")? @map("blocked_period") // Native Postgres Range Type
  blockedQuantity Int                       @default(1) @map("blocked_quantity")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem               @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([inventoryItemId])
  // Note: GiST index for blocked_period must be added via raw SQL migration
  @@map("blackout_periods")
}


// --- Transactional Entities ---

enum CustomerStatus {
  ACTIVE
  SUSPENDED
  BLACKLISTED
  PENDING_KYC
  INACTIVE
}

model Customer {
  id     String         @id @default(uuid())
  tenantId String       @map("tenant_id")
  name   String
  email  String
  status CustomerStatus @default(ACTIVE)
  phone  String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([tenantId])
  @@map("customers")
}

model Promotion {
  id         String    @id @default(uuid())
  name       String
  code       String?   @unique // Unique per tenant logic handled by DB or App
  isActive   Boolean   @default(true) @map("is_active")
  validFrom  DateTime  @map("valid_from")
  validTo    DateTime  @map("valid_to")
  rules      Json      // Condition logic
  reward     Json      // Benefit definition

  // Relations
  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String           @map("tenant_id")
  bookingDiscounts BookingDiscount[]

  @@index([tenantId])
  @@map("promotions")
}

model Booking {
  id            String        @id @default(uuid())
  rentalPeriod  Unsupported("tstzrange")? @map("rental_period")
  status        BookingStatus @default(RESERVED)
  subtotal      Decimal       @db.Decimal(10, 2)
  totalDiscount Decimal       @default(0) @map("total_discount") @db.Decimal(10, 2)
  totalTax      Decimal       @default(0) @map("total_tax") @db.Decimal(10, 2)
  grandTotal    Decimal       @map("grand_total") @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId      String           @map("tenant_id")
  customer      Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  customerId    String           @map("customer_id")

  lineItems     BookingLineItem[]
  discounts     BookingDiscount[]

  @@index([tenantId])
  @@index([customerId])
  // Note: GiST index for rental_period must be added via raw SQL migration
  @@map("bookings")
}

model BookingLineItem {
  id                  String        @id @default(uuid())

  productId           String        @map("product_id")
  inventoryItemId     String?       @map("inventory_item_id")

  status              BookingStatus @default(RESERVED)
  quantityRented      Int           @map("quantity_rented")
  unitPrice           Decimal       @map("unit_price") @db.Decimal(10, 2)
  lineTotal           Decimal       @map("line_total") @db.Decimal(10, 2)

  ownerId             String?       @map("owner_id")
  isExternallySourced Boolean       @default(false) @map("is_externally_sourced")
  priceBreakdown      Json?         @map("price_breakdown")

  booking         Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId       String         @map("booking_id")
  product         Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  owner           Owner?         @relation(fields: [ownerId], references: [id])

  @@index([bookingId])
  @@index([productId])
  @@index([inventoryItemId])
  @@index([ownerId])
  // Note: EXCLUDE constraint (double booking prevention) and CHECK constraint (XOR logic)
  // must be added via raw SQL migration
  @@map("booking_line_items")
}

model BookingDiscount {
  id                 String   @id @default(uuid())
  description        String   // Snapshot
  discountAmount     Decimal  @map("discount_amount") @db.Decimal(10, 2) // Snapshot
  affectedLineItems  Json     @map("affected_line_items") // Metadata

  // Relations
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId      String      @map("tenant_id")
  booking       Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId     String      @map("booking_id")
  promotion     Promotion?  @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  promotionId   String?     @map("promotion_id")

  @@index([tenantId])
  @@index([bookingId])
  @@map("booking_discounts")
}
