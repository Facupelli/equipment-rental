generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum OrderStatus {
  PENDING_SOURCING
  SOURCED
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum OrderItemType {
  PRODUCT
  BUNDLE
}

enum AssignmentType {
  ORDER
  BLACKOUT
  MAINTENANCE
}

enum AssignmentSource {
  OWNED
  EXTERNAL
}

enum TrackingMode {
  IDENTIFIED
  POOLED
}

enum PricingRuleType {
  SEASONAL
  VOLUME
  COUPON
  CUSTOMER_SPECIFIC
}

enum PricingRuleScope {
  ORDER
  PRODUCT_TYPE
  CATEGORY
  BUNDLE
}

// ---------------------------------------------------------------------------
// USER (tenant back-office accounts)
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  email        String
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  isActive     Boolean   @default(true) @map("is_active")

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  refreshTokens    UserRefreshToken[]
  userRoles        UserRole[]
  reviewedProfiles CustomerProfile[]
  
  @@unique([tenantId, email])
  @@index([tenantId, isActive, deletedAt])
  @@map("users")
}

model UserRefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")

  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenHash])
  @@map("user_refresh_tokens")
}

// ---------------------------------------------------------------------------
// CUSTOMER (end-user booking accounts)
// ---------------------------------------------------------------------------

model Customer {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  email        String
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  isCompany    Boolean   @default(false) @map("is_company")
  companyName  String?   @map("company_name")
  taxId        String?   @map("tax_id")
  isActive     Boolean   @default(true) @map("is_active")
  onboardingStatus OnboardingStatus @default(NOT_STARTED) @map("onboarding_status")

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  profile       CustomerProfile?
  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  refreshTokens CustomerRefreshToken[]
  orders        Order[]

  @@unique([tenantId, email])
  @@index([tenantId, isActive, deletedAt])
  @@index([tenantId, isCompany])
  @@map("customers")
}

enum OnboardingStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

enum ProfileSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model CustomerProfile {
  id         String                 @id @default(uuid())
  customerId String                 @unique @map("customer_id")
  status     ProfileSubmissionStatus @default(PENDING)

  // Personal
  fullName             String    @map("full_name")
  phone                String
  birthDate            DateTime  @map("birth_date") @db.Date
  documentNumber       String    @map("document_number")
  identityDocumentPath String    @map("identity_document_path")

  // Address
  address     String
  city        String
  stateRegion String @map("state_region")
  country     String

  // Professional
  occupation   String
  company      String?
  taxId        String?  @map("tax_id")
  businessName String?  @map("business_name")

  // Bank
  bankName      String @map("bank_name")
  accountNumber String @map("account_number")

  // Reference contacts
  contact1Name         String  @map("contact1_name")
  contact1Relationship String  @map("contact1_relationship")
  contact2Name         String  @map("contact2_name")
  contact2Relationship String  @map("contact2_relationship")

  // Review
  rejectionReason String?   @map("rejection_reason")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedById    String?   @map("reviewed_by_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  customer   Customer @relation(fields: [customerId], references: [id])
  reviewedBy User?    @relation(fields: [reviewedById], references: [id])

  @@index([status])
  @@map("customer_profiles")
}

model CustomerRefreshToken {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  tokenHash  String   @map("token_hash")

  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  revokedAt  DateTime? @map("revoked_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([tokenHash])
  @@map("customer_refresh_tokens")
}

// ---------------------------------------------------------------------------
// TENANT
// ---------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  config    Json

  locations           Location[]
  productTypes        ProductType[]
  productCategories   ProductCategory[]
  bundles             Bundle[]
  pricingRules        PricingRule[]
  billingUnits        TenantBillingUnit[]
  owners              Owner[]
  users               User[]
  customers           Customer[]
  roles               Role[]
  invitations         Invitation[]
  TenantOrderSequence TenantOrderSequence[]

  @@map("tenants")
}

// ---------------------------------------------------------------------------
// LOCATION
// ---------------------------------------------------------------------------

model Location {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant  @relation(fields: [tenantId], references: [id])
  assets       Asset[]
  orders       Order[]
  userRoles    UserRole[]
  invitations  Invitation[]
  pricingTiers PricingTier[]

  @@index([tenantId, isActive])
  @@map("locations")
}

// ---------------------------------------------------------------------------
// OWNER
// ---------------------------------------------------------------------------

model Owner {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  email     String?
  phone     String?
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  assets Asset[]

  @@index([tenantId, isActive])
  @@map("owners")
}

// ---------------------------------------------------------------------------
// BILLING UNIT
// ---------------------------------------------------------------------------

model BillingUnit {
  id              String @id @default(uuid())
  label           String @unique
  durationMinutes Int    @map("duration_minutes")
  sortOrder       Int    @map("sort_order")

  tenantBillingUnits TenantBillingUnit[]
  productTypes       ProductType[]
  bundles            Bundle[]

  @@map("billing_units")
}

model TenantBillingUnit {
  id            String @id @default(uuid())
  tenantId      String @map("tenant_id")
  billingUnitId String @map("billing_unit_id")

  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  billingUnit   BillingUnit @relation(fields: [billingUnitId], references: [id])

  @@unique([tenantId, billingUnitId])
  @@map("tenant_billing_units")
}

// ---------------------------------------------------------------------------
// PRODUCT
// ---------------------------------------------------------------------------

model ProductCategory {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  productTypes ProductType[]

  @@unique([tenantId, name])
  @@map("product_categories")
}

model ProductType {
  id            String       @id @default(uuid())
  tenantId      String       @map("tenant_id")
  categoryId    String?      @map("category_id")
  billingUnitId String       @map("billing_unit_id")
  name          String
  description   String?
  imageUrl      String?      @map("image_url")
  trackingMode  TrackingMode @map("tracking_mode")
  attributes    Json
  includedItems Json         @default("[]") @map("included_items")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")
  publishedAt   DateTime?    @map("published_at")
  retiredAt     DateTime?    @map("retired_at")


  tenant             Tenant                    @relation(fields: [tenantId], references: [id])
  category           ProductCategory?          @relation(fields: [categoryId], references: [id])
  billingUnit        BillingUnit               @relation(fields: [billingUnitId], references: [id])
  assets             Asset[]
  pricingTiers       PricingTier[]
  bundleComponents   BundleComponent[]
  snapshotComponents BundleSnapshotComponent[]
  orderItems         OrderItem[]

  @@index([tenantId, publishedAt, deletedAt, categoryId])
  @@map("product_types")
}

// ---------------------------------------------------------------------------
// ASSET
// ---------------------------------------------------------------------------

model Asset {
  id            String    @id @default(uuid())
  locationId    String    @map("location_id")
  productTypeId String    @map("product_type_id")
  ownerId       String?   @map("owner_id")
  serialNumber  String?   @map("serial_number")
  notes         String?
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  location    Location          @relation(fields: [locationId], references: [id])
  productType ProductType       @relation(fields: [productTypeId], references: [id])
  owner       Owner?            @relation(fields: [ownerId], references: [id])
  assignments AssetAssignment[]

  @@index([locationId, productTypeId, isActive, deletedAt])
  @@index([productTypeId, locationId, isActive, deletedAt])
  @@map("assets")
}

// ---------------------------------------------------------------------------
// ASSET ASSIGNMENT
// ---------------------------------------------------------------------------

// tstzrange is not natively supported by Prisma.
// The `period` field is intentionally omitted from Prisma client queries —
// it is managed entirely via raw SQL in AssetAssignmentRepository.
// Prisma will return `period` as a raw string when selected via queryRaw.
//
// Required raw SQL migration:
//   CREATE EXTENSION IF NOT EXISTS btree_gist;
//   ALTER TABLE asset_assignments ADD COLUMN period tstzrange NOT NULL;
//   ALTER TABLE asset_assignments
//     ADD CONSTRAINT no_asset_overlap
//     EXCLUDE USING gist (asset_id WITH =, period WITH &&);

model AssetAssignment {
  id          String            @id @default(uuid())
  assetId     String            @map("asset_id")
  orderItemId String?           @map("order_item_id")
  orderId     String?           @map("order_id")
  type        AssignmentType
  source      AssignmentSource?
  reason      String?
  period      Unsupported("tstzrange")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  asset     Asset      @relation(fields: [assetId], references: [id])
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])
  order     Order?     @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([orderItemId])
  @@index([assetId, type])
  @@map("asset_assignments")
}

// ---------------------------------------------------------------------------
// ORDER
// ---------------------------------------------------------------------------

model Order {
  id           String      @id @default(uuid())
  tenantId     String      @map("tenant_id")
  locationId   String      @map("location_id")
  customerId   String?     @map("customer_id")
  status       OrderStatus @default(PENDING_SOURCING)
  orderNumber  Int         @map("order_number")
  notes        String?

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")

  location         Location          @relation(fields: [locationId], references: [id])
  items            OrderItem[]
  assetAssignments AssetAssignment[]
  customer         Customer? @relation(fields: [customerId], references: [id])

  @@index([tenantId, locationId, status, createdAt(sort: Desc)])
  @@index([tenantId, deletedAt])
  @@unique([tenantId, orderNumber])
  @@map("orders")
}

model OrderItem {
  id               String        @id @default(uuid())
  orderId          String        @map("order_id")
  type             OrderItemType
  productTypeId    String?       @map("product_type_id")
  bundleId         String?       @map("bundle_id")
  priceSnapshot    Json          @map("price_snapshot")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  order            Order                @relation(fields: [orderId], references: [id])
  productType      ProductType?         @relation(fields: [productTypeId], references: [id])
  bundle           Bundle?              @relation(fields: [bundleId], references: [id])
  assetAssignments AssetAssignment[]
  bundleSnapshot   BundleSnapshot?

  @@index([orderId])
  @@map("order_items")
}

model TenantOrderSequence {
  tenantId    String    @id @map("tenant_id")
  lastNumber  Int       @default(0) @map("last_number")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@map("tenant_order_sequences")
}

// ---------------------------------------------------------------------------
// BUNDLE
// ---------------------------------------------------------------------------

model Bundle {
  id            String       @id @default(uuid())
  tenantId      String       @map("tenant_id")
  billingUnitId String       @map("billing_unit_id")
  name          String
  description   String?      
  imageUrl      String?      @map("image_url")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  publishedAt   DateTime?    @map("published_at")
  retiredAt     DateTime?    @map("retired_at")

  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  billingUnit  BillingUnit       @relation(fields: [billingUnitId], references: [id])
  components   BundleComponent[]
  pricingTiers PricingTier[]
  orderItems   OrderItem[]


  @@index([tenantId, publishedAt])
  @@map("bundles")
}

model BundleComponent {
  id            String @id @default(uuid())
  bundleId      String @map("bundle_id")
  productTypeId String @map("product_type_id")
  quantity      Int

  bundle      Bundle      @relation(fields: [bundleId], references: [id])
  productType ProductType @relation(fields: [productTypeId], references: [id])

  @@unique([bundleId, productTypeId])
  @@map("bundle_components")
}

// ---------------------------------------------------------------------------
// BUNDLE SNAPSHOT
// ---------------------------------------------------------------------------

model BundleSnapshot {
  id          String   @id @default(uuid())
  orderItemId String   @unique @map("order_item_id")
  bundleId    String   @map("bundle_id")
  bundleName  String   @map("bundle_name")
  bundlePrice Decimal  @map("bundle_price")
  createdAt   DateTime @default(now()) @map("created_at")

  orderItem  OrderItem               @relation(fields: [orderItemId], references: [id])
  components BundleSnapshotComponent[]

  @@map("bundle_snapshots")
}

model BundleSnapshotComponent {
  id               String @id @default(uuid())
  bundleSnapshotId String @map("bundle_snapshot_id")
  productTypeId    String @map("product_type_id")
  productTypeName  String @map("product_type_name")
  quantity         Int

  bundleSnapshot BundleSnapshot @relation(fields: [bundleSnapshotId], references: [id])
  productType    ProductType    @relation(fields: [productTypeId], references: [id])

  @@map("bundle_snapshot_components")
}

// ---------------------------------------------------------------------------
// PRICING
// ---------------------------------------------------------------------------

model PricingTier {
  id            String   @id @default(uuid())
  productTypeId String?  @map("product_type_id")
  bundleId      String?  @map("bundle_id")
  // pricing tied to specific location
  locationId    String?  @map("location_id")
  fromUnit      Int      @map("from_unit")
  toUnit        Int?     @map("to_unit")
  pricePerUnit  Decimal  @map("price_per_unit")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  productType ProductType? @relation(fields: [productTypeId], references: [id])
  bundle      Bundle?      @relation(fields: [bundleId], references: [id])
  location    Location?    @relation(fields: [locationId], references: [id])

  @@unique([productTypeId, locationId, fromUnit])
  @@unique([bundleId, locationId, fromUnit])
  @@map("pricing_tiers")
}

model PricingRule {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  type      PricingRuleType
  scope     PricingRuleScope
  priority  Int
  stackable Boolean          @default(false)
  isActive  Boolean          @default(true) @map("is_active")
  condition Json
  effect    Json
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, isActive, type, scope])
  @@map("pricing_rules")
}


// ---------------------------------------------------------------------------
// PERMISSIONS & ROLES
// ---------------------------------------------------------------------------

enum Permission {
  // Orders
  VIEW_ORDERS
  CREATE_ORDERS
  CONFIRM_ORDERS
  CANCEL_ORDERS

  // Assets
  VIEW_ASSETS
  CREATE_ASSETS
  UPDATE_ASSETS
  DELETE_ASSETS

  // Asset Assignments
  VIEW_ASSET_ASSIGNMENTS
  MANAGE_ASSET_ASSIGNMENTS

  // Products
  VIEW_PRODUCTS
  CREATE_PRODUCTS
  UPDATE_PRODUCTS
  DELETE_PRODUCTS

  // Bundles
  VIEW_BUNDLES
  MANAGE_BUNDLES

  // Pricing
  VIEW_PRICING
  MANAGE_PRICING

  // Customers
  VIEW_CUSTOMERS
  MANAGE_CUSTOMERS

  // Owners
  VIEW_OWNERS
  MANAGE_OWNERS

  // Locations
  VIEW_LOCATIONS
  MANAGE_LOCATIONS

  // Users & Roles
  VIEW_USERS
  MANAGE_USERS
  MANAGE_ROLES
  INVITE_USERS
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  permissions RolePermission[]
  userRoles   UserRole[]
  invitations Invitation[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model RolePermission {
  id         String     @id @default(uuid())
  roleId     String     @map("role_id")
  permission Permission
  createdAt  DateTime   @default(now()) @map("created_at")

  role Role @relation(fields: [roleId], references: [id])

  @@unique([roleId, permission])
  @@map("role_permissions")
}

// ---------------------------------------------------------------------------
// USER ROLE ASSIGNMENT
// ---------------------------------------------------------------------------

model UserRole {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  roleId     String    @map("role_id")
  locationId String?   @map("location_id")
  createdAt  DateTime  @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id])
  role     Role      @relation(fields: [roleId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  @@unique([userId, roleId, locationId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ---------------------------------------------------------------------------
// INVITATION
// ---------------------------------------------------------------------------

model Invitation {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  email      String
  roleId     String    @map("role_id")
  locationId String?   @map("location_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  role     Role      @relation(fields: [roleId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tokenHash])
  @@map("invitations")
}
