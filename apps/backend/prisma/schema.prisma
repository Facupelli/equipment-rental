// =============================================================================
// Prisma Schema — Equipment Rental SaaS
// =============================================================================
// Notes:
//   - Every table is tenant-scoped via tenantId.
//   - booking_range (tstzrange) is NOT representable in Prisma's type system.
//     It is defined via a raw migration. The field is intentionally omitted here
//     and accessed exclusively through $queryRaw / $executeRaw.
//   - Check constraints and GiST indexes are also defined in raw migrations.
// =============================================================================

generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum TrackingType {
  SERIALIZED
  BULK
}

enum InventoryStatus {
  OPERATIONAL
  MAINTENANCE
  RETIRED
}

enum BookingStatus {
  PENDING_CONFIRMATION 
  RESERVED
  ACTIVE
  COMPLETED
  CANCELLED
}

// --- Core Entities  ---

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  isActive     Boolean  @default(true) @map("is_active")
  tenantId     String   @map("tenant_id")
  roleId       String   @map("role_id")
  
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  role         Role     @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]

  @@index([tenantId]) // Critical for RLS
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @map("token_hash")
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Role {
  id          String       @id @default(cuid())
  name        String
  description String?
  isSystem    Boolean      @default(false) @map("is_system")
  tenantId    String       @map("tenant_id")
  
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  users       User[]
  permissions Permission[]

  @@unique([tenantId, name]) // Role names unique per tenant
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id         String   @id @default(cuid())
  action     String   // e.g., "read", "manage"
  subject    String   // e.g., "Booking"
  conditions Json?    // CASL conditions
  fields     String?  // Optional field masking
  inverted   Boolean  @default(false)
  roleId     String   @map("role_id")

  role       Role     @relation(fields: [roleId], references: [id])

  @@index([roleId])
  @@map("permissions")
}

// --- Tenancy & Organization ---

model Tenant {
  id               String     @id @default(uuid())
  name             String
  slug             String     @unique
  planTier         String     @map("plan_tier")
  isActive         Boolean    @default(true) @map("is_active")
  config           Json?       

  users            User[]
  roles            Role[]
  createdAt        DateTime   @default(now()) @map("created_at")

  // Relations
  categories         Category[]
  locations          Location[]
  owners             Owner[]
  products           Product[]
  inventoryItems     InventoryItem[]
  customers          Customer[]
  orders             Order[]
  bookings           Booking[]
  billingUnits       BillingUnit[]
  pricingTiers       PricingTier[]
  blackoutPeriods    BlackoutPeriod[] 
  productBundles     ProductBundle[]
  bundlePricingTiers BundlePricingTier[]

  @@map("tenants")
}

model BillingUnit {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  name          String        // "half_day" | "full_day" | "week"
  durationHours Decimal       @map("duration_hours") @db.Decimal(6, 2)
  sortOrder     Int           @map("sort_order")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  pricingTiers       PricingTier[]
  bundlePricingTiers BundlePricingTier[]
  tenant        Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@map("billing_units")
}

model Location {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  name      String
  address   Json    // Flexible structure (street, city, geo)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]
  products       Product[]

  @@index([tenantId]) // RLS Index
  @@map("locations")
}

// --- Inventory  ---

model Category {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("categories")
}

// check constraint — BULK must have a location, SERIALIZED may omit it
model Product {
  id                String          @id @default(uuid())
  tenantId          String          @map("tenant_id")
  categoryId        String?         @map("category_id")
  // for bulk items
  locationId        String?          @map("location_id")
  name              String
  trackingType      TrackingType    @map("tracking_type")
  attributes        Json            // Flexible specs (weight, power, etc.)
  includedItems     Json            @default("[]") @map("included_items")

  // Only populated for BULK products. Null for SERIALIZED.
  // Enforced by check constraint in migration:
  //   (tracking_type = 'BULK' AND total_stock IS NOT NULL) OR
  //   (tracking_type = 'SERIALIZED' AND total_stock IS NULL)
  totalStock        Int?            @map("total_stock")

  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")


  // Relations
  location          Location?       @relation(fields: [locationId], references: [id], onDelete: Restrict)
  category          Category?       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItems    InventoryItem[]
  bundleComponents  BundleComponent[]
  pricingTiers      PricingTier[] 
  bookings          Booking[]

  @@index([tenantId])
  @@map("products")
}

model InventoryItem {
  id             String          @id @default(uuid())
  tenantId       String          @map("tenant_id")
  productId      String          @map("product_id")
  locationId     String          @map("location_id")
  status         InventoryStatus @default(OPERATIONAL)
  serialNumber   String?         @map("serial_number")

  // Null means owned by the tenant.
  ownerId        String?             @map("owner_id")

  purchaseDate   DateTime?       @map("purchase_date") @db.Date
  purchaseCost   Decimal?        @map("purchase_cost") @db.Decimal(10, 2)

  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Restrict)
  owner        Owner?        @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  bookings      Booking[]
  pricingTiers     PricingTier[]    // New: Item-level override pricing
  blackoutPeriods  BlackoutPeriod[]

  @@index([tenantId]) // RLS Index
  @@index([productId])
  @@index([locationId])
  @@index([ownerId])
  @@map("inventory_items")
}

// add a check constraint enforcing mutual exclusivity between productId and inventoryItemId
model PricingTier {
  id              String         @id @default(uuid())
  tenantId        String         @map("tenant_id")
  productId       String?        @map("product_id")
  inventoryItemId String?        @map("inventory_item_id")
  billingUnitId   String         @map("billing_unit_id")
  fromUnit        Decimal        @map("from_unit") @db.Decimal(5, 2)
  pricePerUnit    Decimal        @map("price_per_unit") @db.Decimal(10, 2)
  currency        String         @db.Char(3)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  product         Product?       @relation(fields: [productId], references: [id])
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  billingUnit     BillingUnit    @relation(fields: [billingUnitId], references: [id])

  @@unique([tenantId, productId, inventoryItemId, billingUnitId, fromUnit])
  @@map("pricing_tiers")
}


model BlackoutPeriod {
  id              String                    @id @default(uuid())
  tenantId        String                    @map("tenant_id")
  inventoryItemId String                    @map("inventory_item_id")
  reason          String
  blockedPeriod   Unsupported("tstzrange")? @map("blocked_period") // Native Postgres Range Type
  blockedQuantity Int                       @default(1) @map("blocked_quantity")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem               @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([inventoryItemId])
  // Note: GiST index for blocked_period must be added via raw SQL migration
  @@map("blackout_periods")
}

// --- Owners & Revenue Splits ---

model Owner {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  name           String
  notes          String?

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]

  @@index([tenantId]) // RLS Index
  @@map("owners")
}

// --- Bundles ---

model ProductBundle {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  name           String
  description    String?
  isActive       Boolean  @default(true) @map("is_active")
 
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  components     BundleComponent[]
  pricingTiers   BundlePricingTier[]
  bookings       Booking[]

  @@index([tenantId])
  @@map("product_bundles")
}

model BundleComponent {
  id          String @id @default(uuid())
  bundleId    String @map("bundle_id")
  productId   String @map("product_id")
  quantity    Int    @default(1)

  bundle      ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product     Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([bundleId, productId])
  @@map("bundle_components")
}

model BundlePricingTier {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  bundleId      String   @map("bundle_id")
  billingUnitId String   @map("billing_unit_id")
  fromUnit      Decimal  @map("from_unit") @db.Decimal(5, 2)
  pricePerUnit  Decimal  @map("price_per_unit") @db.Decimal(10, 2)
  currency      String   @db.Char(3)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bundle      ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  billingUnit BillingUnit   @relation(fields: [billingUnitId], references: [id])

  @@unique([bundleId, billingUnitId, fromUnit])
  @@index([bundleId])
  @@index([tenantId])
  @@map("bundle_pricing_tiers")
}

// --- Customer ---

enum CustomerStatus {
  ACTIVE
  SUSPENDED
  BLACKLISTED
  PENDING_KYC
  INACTIVE
}

model Customer {
  id             String         @id @default(uuid())
  tenantId       String         @map("tenant_id")
  name           String
  email          String
  status         CustomerStatus @default(ACTIVE)
  phone          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([tenantId])
  @@map("customers")
}

// --- Rental Orders & Bookings ---

model Order {
  id            String                   @id @default(uuid())
  tenantId      String                   @map("tenant_id")
  customerId    String                   @map("customer_id")
  status        BookingStatus            @default(RESERVED)
  notes         String?
  bookingRange  Unsupported("tstzrange") @map("booking_range")
  
  subtotal      Decimal                  @db.Decimal(10, 2)
  totalDiscount Decimal                  @default(0) @map("total_discount") @db.Decimal(10, 2)
  totalTax      Decimal                  @default(0) @map("total_tax") @db.Decimal(10, 2)
  grandTotal    Decimal                  @map("grand_total") @db.Decimal(10, 2)
  
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")

  tenant        Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer      Customer                 @relation(fields: [customerId], references: [id], onDelete: Restrict)
  bookings      Booking[]

  @@index([tenantId])
  @@index([customerId])
  @@map("orders")
}


// A booking is one line within a rental order:
//   - SERIALIZED product: inventoryItemId is set, quantity is null.
//   - BULK product:       quantity is set,         inventoryItemId is null.
//
// This mutual exclusivity is enforced by a check constraint in the migration:
//   (inventory_item_id IS NOT NULL AND quantity IS NULL) OR
//   (inventory_item_id IS NULL     AND quantity IS NOT NULL)
model Booking {
  id                  String        @id @default(uuid())
  tenantId            String        @map("tenant_id")
  orderId             String        @map("order_id")
  productId           String        @map("product_id")
  bundleId            String?       @map("bundle_id") 
   // SERIALIZED only
  inventoryItemId     String? @map("inventory_item_id")
  // BULK only
  quantity            Int?

  unitPrice           Decimal       @map("unit_price") @db.Decimal(10, 2)

  priceBreakdown      Json?         @map("price_breakdown")

  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  order               Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  inventoryItem       InventoryItem?    @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  bundle              ProductBundle?    @relation(fields: [bundleId], references: [id], onDelete: Restrict)

  @@index([tenantId, productId])
  @@index([tenantId, orderId])
  @@map("bookings")
}
