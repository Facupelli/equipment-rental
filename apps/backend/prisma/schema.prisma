generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum OrderStatus {
  PENDING_REVIEW
  CONFIRMED
  REJECTED
  EXPIRED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum OrderItemType {
  PRODUCT
  BUNDLE
}

enum AssignmentType {
  ORDER
  BLACKOUT
  MAINTENANCE
}

enum OrderAssignmentStage {
  HOLD
  COMMITTED
}

enum AssignmentSource {
  OWNED
  EXTERNAL
}

enum TrackingMode {
  IDENTIFIED
  POOLED
}

enum PricingRuleType {
  SEASONAL
  VOLUME
  COUPON
  CUSTOMER_SPECIFIC
  DURATION
}

enum PricingRuleScope {
  ORDER
  PRODUCT_TYPE
  CATEGORY
  BUNDLE
}

enum CustomDomainStatus {
  PENDING
  ACTIVE
  ACTION_REQUIRED
  FAILED
}

// ---------------------------------------------------------------------------
// USER (tenant back-office accounts)
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  email        String
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  isActive     Boolean   @default(true) @map("is_active")

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  userRoles        UserRole[]
  reviewedProfiles CustomerProfile[]
  
  @@unique([tenantId, email])
  @@index([tenantId, isActive, deletedAt])
  @@map("users")
}

// ---------------------------------------------------------------------------
// CUSTOMER (end-user booking accounts)
// ---------------------------------------------------------------------------

model Customer {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  email        String
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  isCompany    Boolean   @default(false) @map("is_company")
  companyName  String?   @map("company_name")
  isActive     Boolean   @default(true) @map("is_active")
  onboardingStatus OnboardingStatus @default(NOT_STARTED) @map("onboarding_status")

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  profile            CustomerProfile?
  tenant             Tenant                  @relation(fields: [tenantId], references: [id])
  orders             Order[]
  restrictedCoupons  Coupon[]
  couponRedemptions  CouponRedemption[]

  @@unique([tenantId, email])
  @@index([tenantId, isActive, deletedAt])
  @@index([tenantId, isCompany])
  @@map("customers")
}

enum OnboardingStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

enum ProfileSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model CustomerProfile {
  id         String                 @id @default(uuid())
  customerId String                 @unique @map("customer_id")
  status     ProfileSubmissionStatus @default(PENDING)

  // Personal
  fullName             String    @map("full_name")
  phone                String
  birthDate            DateTime  @map("birth_date") @db.Date
  documentNumber       String    @map("document_number")
  identityDocumentPath String    @map("identity_document_path")

  // Address
  address     String
  city        String
  stateRegion String @map("state_region")
  country     String

  // Professional
  occupation   String
  company      String?
  taxId        String?  @map("tax_id")
  businessName String?  @map("business_name")

  // Bank
  bankName      String @map("bank_name")
  accountNumber String @map("account_number")

  // Reference contacts
  contact1Name         String  @map("contact1_name")
  contact1Relationship String  @map("contact1_relationship")
  contact2Name         String  @map("contact2_name")
  contact2Relationship String  @map("contact2_relationship")

  // Review
  rejectionReason String?   @map("rejection_reason")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedById    String?   @map("reviewed_by_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  customer   Customer @relation(fields: [customerId], references: [id])
  reviewedBy User?    @relation(fields: [reviewedById], references: [id])

  @@index([status])
  @@map("customer_profiles")
}

// JWT REFRESH TOKENS

enum ActorType {
  USER
  CUSTOMER
}

model RefreshToken {
  id        String    @id @default(uuid())
  actorType ActorType @map("actor_type")
  actorId   String    @map("actor_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  @@index([actorType, actorId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// TENANT
// ---------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid())
  name      String
  config    Json

  slug         String   @unique
  customDomain String?  @unique @map("custom_domain")
  logoUrl      String?  @map("logo_url")
  faviconUrl   String?  @map("favicon_url")
  primaryColor String?  @map("primary_color")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  locations           Location[]
  productTypes        ProductType[]
  productCategories   ProductCategory[]
  bundles             Bundle[]
  pricingRules        PricingRule[]
  billingUnits        TenantBillingUnit[]
  managedCustomDomain CustomDomain?
  owners              Owner[]
  users               User[]
  customers           Customer[]
  roles               Role[]
  invitations         Invitation[]
  TenantOrderSequence TenantOrderSequence[]
  ownerPayments       OwnerPayment[] 
  ownerContracts      OwnerContract[]
  coupons             Coupon[]

  @@map("tenants")
}

model CustomDomain {
  id           String             @id @default(uuid())
  tenantId     String             @unique @map("tenant_id")
  domain       String             @unique
  cfHostnameId String?            @map("cf_hostname_id")
  status       CustomDomainStatus
  verifiedAt   DateTime?          @map("verified_at")
  lastError    String?            @map("last_error")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("custom_domains")
}

// ---------------------------------------------------------------------------
// LOCATION
// ---------------------------------------------------------------------------

model Location {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant  @relation(fields: [tenantId], references: [id])
  schedules    LocationSchedule[]
  assets       Asset[]
  orders       Order[]
  userRoles    UserRole[]
  invitations  Invitation[]
  pricingTiers PricingTier[]

  @@index([tenantId, isActive])
  @@map("locations")
}

enum ScheduleSlotType {
  PICKUP
  RETURN
}

model LocationSchedule {
  id           String           @id @default(uuid())
  locationId   String           @map("location_id")
  type         ScheduleSlotType

  dayOfWeek    Int?             @map("day_of_week")
  specificDate DateTime?        @map("specific_date") @db.Date

  openTime            Int       @map("open_time")
  closeTime           Int       @map("close_time")
  slotIntervalMinutes Int?      @map("slot_interval_minutes")

  location Location @relation(fields: [locationId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("location_schedules")
}



// ---------------------------------------------------------------------------
// OWNER
// ---------------------------------------------------------------------------

model Owner {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  email     String?
  phone     String?
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  assets Asset[]
  contracts OwnerContract[]
  splits    OrderItemOwnerSplit[]
  payments  OwnerPayment[]

  @@index([tenantId, isActive])
  @@map("owners")
}

enum ContractBasis {
  NET_COLLECTED
}

model OwnerContract {
  id          String        @id @default(uuid())
  tenantId    String        @map("tenant_id")
  ownerId     String        @map("owner_id")
  assetId     String?       @map("asset_id")       // null = owner-level default
  ownerShare  Decimal       @map("owner_share")     // e.g. 0.70
  rentalShare Decimal       @map("rental_share")    // e.g. 0.30
  basis       ContractBasis @default(NET_COLLECTED)
  validFrom   DateTime      @map("valid_from")
  validUntil  DateTime?     @map("valid_until")     // null = indefinite
  notes       String?
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant  Tenant              @relation(fields: [tenantId], references: [id])
  owner   Owner               @relation(fields: [ownerId], references: [id])
  asset   Asset?              @relation(fields: [assetId], references: [id])
  splits  OrderItemOwnerSplit[]

  @@index([ownerId, assetId, validFrom, validUntil])
  @@index([tenantId, isActive])
  @@map("owner_contracts")
}

// ---------------------------------------------------------------------------
// BILLING UNIT
// ---------------------------------------------------------------------------

model BillingUnit {
  id              String @id @default(uuid())
  label           String @unique
  durationMinutes Int    @map("duration_minutes")
  sortOrder       Int    @map("sort_order")

  tenantBillingUnits TenantBillingUnit[]
  productTypes       ProductType[]
  bundles            Bundle[]

  @@map("billing_units")
}

model TenantBillingUnit {
  id            String @id @default(uuid())
  tenantId      String @map("tenant_id")
  billingUnitId String @map("billing_unit_id")

  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  billingUnit   BillingUnit @relation(fields: [billingUnitId], references: [id])

  @@unique([tenantId, billingUnitId])
  @@map("tenant_billing_units")
}

// ---------------------------------------------------------------------------
// PRODUCT
// ---------------------------------------------------------------------------

model ProductCategory {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  productTypes ProductType[]

  @@unique([tenantId, name])
  @@map("product_categories")
}

model ProductType {
  id            String       @id @default(uuid())
  tenantId      String       @map("tenant_id")
  categoryId    String?      @map("category_id")
  billingUnitId String       @map("billing_unit_id")
  name          String
  description   String?
  imageUrl      String?      @map("image_url")
  trackingMode  TrackingMode @map("tracking_mode")
  excludeFromNewArrivals Boolean @default(false) @map("exclude_from_new_arrivals")
  attributes    Json
  includedItems Json         @default("[]") @map("included_items")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")
  publishedAt   DateTime?    @map("published_at")
  retiredAt     DateTime?    @map("retired_at")


  tenant             Tenant                    @relation(fields: [tenantId], references: [id])
  category           ProductCategory?          @relation(fields: [categoryId], references: [id])
  billingUnit        BillingUnit               @relation(fields: [billingUnitId], references: [id])
  assets             Asset[]
  pricingTiers       PricingTier[]
  bundleComponents   BundleComponent[]
  snapshotComponents BundleSnapshotComponent[]
  orderItems         OrderItem[]

  @@index([tenantId, publishedAt, deletedAt, categoryId])
  @@map("product_types")
}

// ---------------------------------------------------------------------------
// ASSET
// ---------------------------------------------------------------------------

model Asset {
  id            String    @id @default(uuid())
  locationId    String    @map("location_id")
  productTypeId String    @map("product_type_id")
  ownerId       String?   @map("owner_id")
  serialNumber  String?   @map("serial_number")
  notes         String?
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  location    Location          @relation(fields: [locationId], references: [id])
  productType ProductType       @relation(fields: [productTypeId], references: [id])
  owner       Owner?            @relation(fields: [ownerId], references: [id])
  assignments AssetAssignment[]
  contracts   OwnerContract[]
  splits      OrderItemOwnerSplit[]

  @@index([locationId, productTypeId, isActive, deletedAt])
  @@index([productTypeId, locationId, isActive, deletedAt])
  @@map("assets")
}

// ---------------------------------------------------------------------------
// ASSET ASSIGNMENT
// ---------------------------------------------------------------------------

// tstzrange is not natively supported by Prisma.
// The `period` field is intentionally omitted from Prisma client queries —
// it is managed entirely via raw SQL in AssetAssignmentRepository.
// Prisma will return `period` as a raw string when selected via queryRaw.
//
// Required raw SQL migration:
//   CREATE EXTENSION IF NOT EXISTS btree_gist;
//   ALTER TABLE asset_assignments ADD COLUMN period tstzrange NOT NULL;
//   ALTER TABLE asset_assignments
//     ADD CONSTRAINT no_asset_overlap
//     EXCLUDE USING gist (asset_id WITH =, period WITH &&);

model AssetAssignment {
  id          String            @id @default(uuid())
  assetId     String            @map("asset_id")
  orderItemId String?           @map("order_item_id")
  orderId     String?           @map("order_id")
  type        AssignmentType
  stage       OrderAssignmentStage?
  source      AssignmentSource?
  reason      String?
  period      Unsupported("tstzrange")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  asset     Asset      @relation(fields: [assetId], references: [id])
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])
  order     Order?     @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([orderItemId])
  @@index([assetId, type])
  @@map("asset_assignments")
}

// ---------------------------------------------------------------------------
// ORDER
// ---------------------------------------------------------------------------

model Order {
  id                String      @id @default(uuid())
  tenantId          String      @map("tenant_id")
  locationId        String      @map("location_id")
  customerId        String?     @map("customer_id")
  couponId          String?     @map("coupon_id")
  status            OrderStatus @default(CONFIRMED)
  orderNumber       Int         @map("order_number") @default(0)
  notes             String?
  insuranceSelected Boolean     @default(false) @map("insurance_selected")
  financialSnapshot Json        @default("{}") @map("financial_snapshot")
  periodStart       DateTime    @map("period_start")
  periodEnd         DateTime    @map("period_end")

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")

  location         Location          @relation(fields: [locationId], references: [id])
  items            OrderItem[]
  assetAssignments AssetAssignment[]
  customer         Customer? @relation(fields: [customerId], references: [id])
  coupon           Coupon?  @relation(fields: [couponId], references: [id])
  couponRedemption CouponRedemption?

  @@index([tenantId, locationId, status, createdAt(sort: Desc)])
  @@index([tenantId, locationId, periodStart, periodEnd])
  @@index([tenantId, deletedAt])
  @@unique([tenantId, orderNumber])
  @@map("orders")
}

model OrderItem {
  id               String        @id @default(uuid())
  orderId          String        @map("order_id")
  type             OrderItemType
  productTypeId    String?       @map("product_type_id")
  bundleId         String?       @map("bundle_id")
  priceSnapshot    Json          @map("price_snapshot")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  order            Order                @relation(fields: [orderId], references: [id])
  productType      ProductType?         @relation(fields: [productTypeId], references: [id])
  bundle           Bundle?              @relation(fields: [bundleId], references: [id])
  assetAssignments AssetAssignment[]
  ownerSplits      OrderItemOwnerSplit[] 
  bundleSnapshot   BundleSnapshot?

  @@index([orderId])
  @@map("order_items")
}

model TenantOrderSequence {
  tenantId    String    @id @map("tenant_id")
  lastNumber  Int       @default(0) @map("last_number")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@map("tenant_order_sequences")
}

enum SplitStatus {
  PENDING    // order created, amounts computed
  CONFIRMED  // reserved for future async checkout confirmation
  VOID       // order cancelled or item removed
  SETTLED    // payment recorded
}

model OrderItemOwnerSplit {
  id          String      @id @default(uuid())
  orderItemId String      @map("order_item_id")
  assetId     String      @map("asset_id")
  ownerId     String      @map("owner_id")
  contractId  String      @map("contract_id")
  status      SplitStatus @default(PENDING)

  // snapshot of contract terms at assignment time
  ownerShare  Decimal     @map("owner_share")
  rentalShare Decimal     @map("rental_share")
  basis       ContractBasis

  // computed amounts
  grossAmount  Decimal    @map("gross_amount")
  netAmount    Decimal    @map("net_amount")
  ownerAmount  Decimal    @map("owner_amount")
  rentalAmount Decimal    @map("rental_amount")

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  orderItem OrderItem           @relation(fields: [orderItemId], references: [id])
  asset     Asset               @relation(fields: [assetId], references: [id])
  owner     Owner               @relation(fields: [ownerId], references: [id])
  contract  OwnerContract       @relation(fields: [contractId], references: [id])
  payment   OwnerPaymentSplit?

  @@unique([orderItemId, assetId])
  @@index([ownerId, status])
  @@index([orderItemId])
  @@map("order_item_owner_splits")
}

// ---------------------------------------------------------------------------
// BUNDLE
// ---------------------------------------------------------------------------

model Bundle {
  id            String       @id @default(uuid())
  tenantId      String       @map("tenant_id")
  billingUnitId String       @map("billing_unit_id")
  name          String
  description   String?      
  imageUrl      String?      @map("image_url")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  publishedAt   DateTime?    @map("published_at")
  retiredAt     DateTime?    @map("retired_at")

  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  billingUnit  BillingUnit       @relation(fields: [billingUnitId], references: [id])
  components   BundleComponent[]
  pricingTiers PricingTier[]
  orderItems   OrderItem[]


  @@index([tenantId, publishedAt])
  @@map("bundles")
}

model BundleComponent {
  id            String @id @default(uuid())
  bundleId      String @map("bundle_id")
  productTypeId String @map("product_type_id")
  quantity      Int

  bundle      Bundle      @relation(fields: [bundleId], references: [id])
  productType ProductType @relation(fields: [productTypeId], references: [id])

  @@unique([bundleId, productTypeId])
  @@map("bundle_components")
}

// ---------------------------------------------------------------------------
// BUNDLE SNAPSHOT
// ---------------------------------------------------------------------------

model BundleSnapshot {
  id          String   @id @default(uuid())
  orderItemId String   @unique @map("order_item_id")
  bundleId    String   @map("bundle_id")
  bundleName  String   @map("bundle_name")
  bundlePrice Decimal  @map("bundle_price")
  createdAt   DateTime @default(now()) @map("created_at")

  orderItem  OrderItem               @relation(fields: [orderItemId], references: [id])
  components BundleSnapshotComponent[]

  @@map("bundle_snapshots")
}

model BundleSnapshotComponent {
  id               String @id @default(uuid())
  bundleSnapshotId String @map("bundle_snapshot_id")
  productTypeId    String @map("product_type_id")
  productTypeName  String @map("product_type_name")
  quantity         Int
  pricePerUnit     Decimal @map("price_per_unit") @default(0)  // standalone price at snapshot time

  bundleSnapshot BundleSnapshot @relation(fields: [bundleSnapshotId], references: [id])
  productType    ProductType    @relation(fields: [productTypeId], references: [id])

  @@map("bundle_snapshot_components")
}

// ---------------------------------------------------------------------------
// PRICING
// ---------------------------------------------------------------------------

model PricingTier {
  id            String   @id @default(uuid())
  productTypeId String?  @map("product_type_id")
  bundleId      String?  @map("bundle_id")
  // pricing tied to specific location
  locationId    String?  @map("location_id")
  fromUnit      Int      @map("from_unit")
  toUnit        Int?     @map("to_unit")
  pricePerUnit  Decimal  @map("price_per_unit")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  productType ProductType? @relation(fields: [productTypeId], references: [id])
  bundle      Bundle?      @relation(fields: [bundleId], references: [id])
  location    Location?    @relation(fields: [locationId], references: [id])

  @@unique([productTypeId, locationId, fromUnit])
  @@unique([bundleId, locationId, fromUnit])
  @@map("pricing_tiers")
}

model PricingRule {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  name      String
  type      PricingRuleType
  scope     PricingRuleScope
  priority  Int
  stackable Boolean          @default(false)
  isActive  Boolean          @default(true) @map("is_active")
  condition Json
  effect    Json
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  coupons  Coupon[]

  @@index([tenantId, isActive, type, scope])
  @@map("pricing_rules")
}

// ---------------------------------------------------------------------------
// COUPON
// ---------------------------------------------------------------------------

model Coupon {
  id                     String    @id @default(uuid())
  tenantId               String    @map("tenant_id")
  pricingRuleId          String    @map("pricing_rule_id")
  code                   String
  maxUses                Int?      @map("max_uses")
  maxUsesPerCustomer     Int?      @map("max_uses_per_customer")
  restrictedToCustomerId String?   @map("restricted_to_customer_id")
  validFrom              DateTime? @map("valid_from")
  validUntil             DateTime? @map("valid_until")
  isActive               Boolean   @default(true) @map("is_active")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  tenant             Tenant          @relation(fields: [tenantId], references: [id])
  pricingRule        PricingRule     @relation(fields: [pricingRuleId], references: [id])
  restrictedCustomer Customer?       @relation(fields: [restrictedToCustomerId], references: [id])
  redemptions        CouponRedemption[]
  orders             Order[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("coupons")
}

model CouponRedemption {
  id         String    @id @default(uuid())
  couponId   String    @map("coupon_id")
  orderId    String    @unique @map("order_id")
  customerId String?   @map("customer_id")
  redeemedAt DateTime  @default(now()) @map("redeemed_at")
  voidedAt   DateTime? @map("voided_at")

  coupon   Coupon    @relation(fields: [couponId], references: [id])
  order    Order     @relation(fields: [orderId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@unique([couponId, orderId])
  @@index([couponId, voidedAt])
  @@index([couponId, customerId, voidedAt])
  @@map("coupon_redemptions")
}

// ---------------------------------------------------------------------------
// OWNER PAYMENT
// ---------------------------------------------------------------------------

enum PaymentMethod {
  BANK_TRANSFER
  PIX
  CASH
  OTHER
}

model OwnerPayment {
  id          String        @id @default(uuid())
  tenantId    String        @map("tenant_id")
  ownerId     String        @map("owner_id")
  totalAmount Decimal       @map("total_amount")
  method      PaymentMethod
  reference   String?
  notes       String?
  paidAt      DateTime      @map("paid_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  owner       Owner               @relation(fields: [ownerId], references: [id])
  splits      OwnerPaymentSplit[]

  @@index([tenantId, ownerId, paidAt])
  @@map("owner_payments")
}

model OwnerPaymentSplit {
  id        String @id @default(uuid())
  paymentId String @map("payment_id")
  splitId   String @unique @map("split_id")

  payment OwnerPayment        @relation(fields: [paymentId], references: [id])
  split   OrderItemOwnerSplit @relation(fields: [splitId], references: [id])

  @@map("owner_payment_splits")
}


// ---------------------------------------------------------------------------
// PERMISSIONS & ROLES
// ---------------------------------------------------------------------------

enum Permission {
  // Orders
  VIEW_ORDERS
  CREATE_ORDERS
  CONFIRM_ORDERS
  CANCEL_ORDERS

  // Assets
  VIEW_ASSETS
  CREATE_ASSETS
  UPDATE_ASSETS
  DELETE_ASSETS

  // Asset Assignments
  VIEW_ASSET_ASSIGNMENTS
  MANAGE_ASSET_ASSIGNMENTS

  // Products
  VIEW_PRODUCTS
  CREATE_PRODUCTS
  UPDATE_PRODUCTS
  DELETE_PRODUCTS

  // Bundles
  VIEW_BUNDLES
  MANAGE_BUNDLES

  // Pricing
  VIEW_PRICING
  MANAGE_PRICING

  // Customers
  VIEW_CUSTOMERS
  MANAGE_CUSTOMERS

  // Owners
  VIEW_OWNERS
  MANAGE_OWNERS

  // Locations
  VIEW_LOCATIONS
  MANAGE_LOCATIONS

  // Users & Roles
  VIEW_USERS
  MANAGE_USERS
  MANAGE_ROLES
  INVITE_USERS
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  code        String   @default("TENANT_ADMIN")
  name        String
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  permissions RolePermission[]
  userRoles   UserRole[]
  invitations Invitation[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model RolePermission {
  id         String     @id @default(uuid())
  roleId     String     @map("role_id")
  permission Permission
  createdAt  DateTime   @default(now()) @map("created_at")

  role Role @relation(fields: [roleId], references: [id])

  @@unique([roleId, permission])
  @@map("role_permissions")
}

// ---------------------------------------------------------------------------
// USER ROLE ASSIGNMENT
// ---------------------------------------------------------------------------

model UserRole {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  roleId     String    @map("role_id")
  locationId String?   @map("location_id")
  createdAt  DateTime  @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id])
  role     Role      @relation(fields: [roleId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  @@unique([userId, roleId, locationId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ---------------------------------------------------------------------------
// INVITATION
// ---------------------------------------------------------------------------

model Invitation {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  email      String
  roleId     String    @map("role_id")
  locationId String?   @map("location_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  role     Role      @relation(fields: [roleId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tokenHash])
  @@map("invitations")
}
