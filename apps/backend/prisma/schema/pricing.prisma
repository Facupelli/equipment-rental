enum PromotionType {
  COUPON
  SEASONAL
  CUSTOMER_SPECIFIC
}

// ---------------------------------------------------------------------------
// PRICING
// ---------------------------------------------------------------------------

model PricingTier {
  id            String   @id @default(uuid())
  productTypeId String?  @map("product_type_id")
  bundleId      String?  @map("bundle_id")
  // pricing tied to specific location
  locationId    String?  @map("location_id")
  fromUnit      Int      @map("from_unit")
  toUnit        Int?     @map("to_unit")
  pricePerUnit  Decimal  @map("price_per_unit")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  productType ProductType? @relation(fields: [productTypeId], references: [id])
  bundle      Bundle?      @relation(fields: [bundleId], references: [id])
  location    Location?    @relation(fields: [locationId], references: [id])

  @@unique([productTypeId, locationId, fromUnit])
  @@unique([bundleId, locationId, fromUnit])
  @@map("pricing_tiers")
}

// ---------------------------------------------------------------------------
// PROMOTIONS
// ---------------------------------------------------------------------------

model Promotion {
  id        String        @id @default(uuid())
  tenantId  String        @map("tenant_id")
  name      String
  type      PromotionType
  priority  Int
  stackable Boolean       @default(false)
  isActive  Boolean       @default(true) @map("is_active")
  condition Json
  effect    Json
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  coupons    Coupon[]
  exclusions PromotionExclusion[]

  @@index([tenantId, isActive, type, priority])
  @@map("promotions")
}

model PromotionExclusion {
  id            String   @id @default(uuid())
  promotionId   String   @map("promotion_id")
  productTypeId String?  @map("product_type_id")
  bundleId      String?  @map("bundle_id")
  createdAt     DateTime @default(now()) @map("created_at")

  promotion   Promotion    @relation(fields: [promotionId], references: [id])
  productType ProductType? @relation(fields: [productTypeId], references: [id])
  bundle      Bundle?      @relation(fields: [bundleId], references: [id])

  @@unique([promotionId, productTypeId])
  @@unique([promotionId, bundleId])
  @@index([promotionId])
  @@map("promotion_exclusions")
}

// ---------------------------------------------------------------------------
// TODO: longrentaldiscount and longrentaldiscountexclusion should be deleted?
// ---------------------------------------------------------------------------

model LongRentalDiscount {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  priority  Int
  isActive  Boolean  @default(true) @map("is_active")
  tiers     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant                        @relation(fields: [tenantId], references: [id])
  exclusions LongRentalDiscountExclusion[]

  @@index([tenantId, isActive, priority])
  @@map("long_rental_discounts")
}

model LongRentalDiscountExclusion {
  id                   String   @id @default(uuid())
  longRentalDiscountId String   @map("long_rental_discount_id")
  productTypeId        String?  @map("product_type_id")
  bundleId             String?  @map("bundle_id")
  createdAt            DateTime @default(now()) @map("created_at")

  longRentalDiscount LongRentalDiscount @relation(fields: [longRentalDiscountId], references: [id])
  productType        ProductType?       @relation(fields: [productTypeId], references: [id])
  bundle             Bundle?            @relation(fields: [bundleId], references: [id])

  @@unique([longRentalDiscountId, productTypeId])
  @@unique([longRentalDiscountId, bundleId])
  @@index([longRentalDiscountId])
  @@map("long_rental_discount_exclusions")
}

// ---------------------------------------------------------------------------
// COUPON
// ---------------------------------------------------------------------------

model Coupon {
  id                     String    @id @default(uuid())
  tenantId               String    @map("tenant_id")
  promotionId            String    @map("promotion_id")
  code                   String
  maxUses                Int?      @map("max_uses")
  maxUsesPerCustomer     Int?      @map("max_uses_per_customer")
  restrictedToCustomerId String?   @map("restricted_to_customer_id")
  validFrom              DateTime? @map("valid_from")
  validUntil             DateTime? @map("valid_until")
  isActive               Boolean   @default(true) @map("is_active")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  promotion          Promotion          @relation(fields: [promotionId], references: [id])
  restrictedCustomer Customer?          @relation(fields: [restrictedToCustomerId], references: [id])
  redemptions        CouponRedemption[]
  orders             Order[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("coupons")
}

model CouponRedemption {
  id         String    @id @default(uuid())
  couponId   String    @map("coupon_id")
  orderId    String    @unique @map("order_id")
  customerId String?   @map("customer_id")
  redeemedAt DateTime  @default(now()) @map("redeemed_at")
  voidedAt   DateTime? @map("voided_at")

  coupon   Coupon    @relation(fields: [couponId], references: [id])
  order    Order     @relation(fields: [orderId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@unique([couponId, orderId])
  @@index([couponId, voidedAt])
  @@index([couponId, customerId, voidedAt])
  @@map("coupon_redemptions")
}
