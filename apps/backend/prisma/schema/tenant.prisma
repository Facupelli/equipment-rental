enum ScheduleSlotType {
  PICKUP
  RETURN
}

// ---------------------------------------------------------------------------
// TENANT
// ---------------------------------------------------------------------------

model Tenant {
  id     String @id @default(uuid())
  name   String
  config Json

  slug         String  @unique
  customDomain String? @unique @map("custom_domain")
  logoUrl      String? @map("logo_url")
  faviconUrl   String? @map("favicon_url")
  primaryColor String? @map("primary_color")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  locations           Location[]
  productTypes        ProductType[]
  productCategories   ProductCategory[]
  bundles             Bundle[]
  longRentalDiscounts LongRentalDiscount[]
  promotions          Promotion[]
  billingUnits        TenantBillingUnit[]
  managedCustomDomain CustomDomain?
  owners              Owner[]
  users               User[]
  customers           Customer[]
  signingRequests     DocumentSigningRequest[]
  roles               Role[]
  invitations         Invitation[]
  TenantOrderSequence TenantOrderSequence[]
  ownerPayments       OwnerPayment[]
  ownerContracts      OwnerContract[]
  coupons             Coupon[]
  externalIdentities  ExternalIdentity[]
  accessoryLinks      AccessoryLink[]

  @@map("tenants")
}

model CustomDomain {
  id           String             @id @default(uuid())
  tenantId     String             @unique @map("tenant_id")
  domain       String             @unique
  cfHostnameId String?            @map("cf_hostname_id")
  status       CustomDomainStatus
  verifiedAt   DateTime?          @map("verified_at")
  lastError    String?            @map("last_error")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("custom_domains")
}

// ---------------------------------------------------------------------------
// LOCATION
// ---------------------------------------------------------------------------

model Location {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  name     String
  address  String?
  timezone String?
  isActive Boolean @default(true) @map("is_active")

  supportsDelivery           Boolean @default(false) @map("supports_delivery")
  deliveryDefaultCountry     String? @map("delivery_default_country")
  deliveryDefaultStateRegion String? @map("delivery_default_state_region")
  deliveryDefaultCity        String? @map("delivery_default_city")
  deliveryDefaultPostalCode  String? @map("delivery_default_postal_code")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  schedules    LocationSchedule[]
  assets       Asset[]
  orders       Order[]
  userRoles    UserRole[]
  invitations  Invitation[]
  pricingTiers PricingTier[]

  @@index([tenantId, isActive])
  @@map("locations")
}

model LocationSchedule {
  id         String           @id @default(uuid())
  locationId String           @map("location_id")
  type       ScheduleSlotType

  dayOfWeek    Int?      @map("day_of_week")
  specificDate DateTime? @map("specific_date") @db.Date

  openTime            Int  @map("open_time")
  closeTime           Int  @map("close_time")
  slotIntervalMinutes Int? @map("slot_interval_minutes")

  location Location @relation(fields: [locationId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("location_schedules")
}
