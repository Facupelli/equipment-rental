enum SigningDocumentType {
  RENTAL_AGREEMENT
}

enum DocumentSigningRequestStatus {
  PENDING
  SIGNED
  EXPIRED
  VOIDED
}

// ---------------------------------------------------------------------------
// DOCUMENT SIGNING REQUEST
// ---------------------------------------------------------------------------

model DocumentSigningRequest {
  id                    String                       @id @default(uuid())
  tenantId              String                       @map("tenant_id")
  orderId               String                       @map("order_id")
  customerId            String?                      @map("customer_id")
  documentType          SigningDocumentType          @map("document_type")
  documentNumber        String                       @map("document_number")
  recipientEmail        String                       @map("recipient_email")
  tokenHash             String                       @unique @map("token_hash")
  documentHash          String                       @map("document_hash")
  pdfStorageKey         String                       @map("pdf_storage_key")
  pdfFileName           String                       @map("pdf_file_name")
  pdfContentType        String                       @default("application/pdf") @map("pdf_content_type")
  pdfByteSize           Int                          @map("pdf_byte_size")
  status                DocumentSigningRequestStatus @default(PENDING)
  expiresAt             DateTime                     @map("expires_at")
  signedAt              DateTime?                    @map("signed_at")
  signerFullName        String?                      @map("signer_full_name")
  signerDocumentNumber  String?                      @map("signer_document_number")
  signatureImageDataUrl String?                      @map("signature_image_data_url") @db.Text
  acceptanceTextVersion String?                      @map("acceptance_text_version")
  createdAt             DateTime                     @default(now()) @map("created_at")
  updatedAt             DateTime                     @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  order    Order     @relation(fields: [orderId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  // Active-request uniqueness is enforced with a manual partial unique index in SQL
  // because Prisma cannot model `WHERE status = 'PENDING'` here.
  @@index([tenantId])
  @@index([orderId])
  @@index([customerId])
  @@index([tenantId, status, expiresAt])
  @@index([tenantId, orderId, documentType])
  @@map("document_signing_requests")
}
