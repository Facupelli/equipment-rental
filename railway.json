{
  "$schema": "https://schema.railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "preDeployCommand": "node -e \"require('child_process').execSync('pnpm --filter @repo/backend exec prisma migrate deploy', {stdio: 'inherit'})\"",
    "startCommand": "node apps/backend/dist/main",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
