{
  "name": "@repo/schemas",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@repo/types": "workspace:*",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.1.3"
  }
}
